{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "moduleResolution": "Node",
        "outDir": "dist-server",
        "rootDir": ".",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true
    },
    "include": [
        "server.ts",
        "server/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}